# ─────────────────────────────────────────────────────────────────────
# Zupwell Frontend — Environment Variables
# Copy to .env.local for development, set in Vercel for production.
# ─────────────────────────────────────────────────────────────────────

# Backend API URL (no trailing slash)
NEXT_PUBLIC_API_URL="https://your-api.onrender.com"

# Chat widget API (optional — defaults to whatsappchatbot URL if not set)
NEXT_PUBLIC_CHAT_API_URL="https://your-api.onrender.com"
