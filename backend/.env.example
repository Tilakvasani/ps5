# ─────────────────────────────────────────────────────────────────────
# Zupwell — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit your actual .env file to Git.
# ─────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/zupwell_db?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/zupwell_db"

# ── Auth ─────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-minimum-64-chars"

# ── Google OAuth ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Razorpay ──────────────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_live_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"

# ── Cloudinary (product image uploads) ───────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ── BaseLinker (eHandler) ─────────────────────────────────────────────
# Get this token from eHandler OR from BaseLinker → My Account → API
BASELINKER_TOKEN="paste-your-token-here"

# ── Twilio SMS (OTP login) ────────────────────────────────────────────
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="your-twilio-phone-number"

# ── URLs ──────────────────────────────────────────────────────────────
FRONTEND_URL="https://your-site.vercel.app"
BACKEND_URL="https://your-api.onrender.com"
NODE_ENV="production"
PORT=8000
